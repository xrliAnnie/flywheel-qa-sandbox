{
	"name": "flywheel-teamlead",
	"version": "0.5.0",
	"description": "Flywheel bridge — REST API for OpenClaw agent integration",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"teamlead": "dist/index.js"
	},
	"scripts": {
		"build": "tsc && cp -r static dist/static",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"test:run": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"express": "^5.2.1",
		"flywheel-claude-runner": "workspace:*",
		"flywheel-core": "workspace:*",
		"flywheel-edge-worker": "workspace:*",
		"flywheel-comm": "workspace:*",
		"@linear/sdk": "60.0.0",
		"sql.js": "^1.14.1"
	},
	"devDependencies": {
		"@types/express": "^5.0.6",
		"@types/node": "^20.0.0",
		"@types/sql.js": "^1.4.9",
		"typescript": "^5.3.3",
		"vitest": "^3.1.4"
	}
}
