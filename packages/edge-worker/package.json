{
	"name": "flywheel-edge-worker",
	"version": "0.2.24",
	"description": "Unified edge worker for processing Linear issues with Claude",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"prompt-template-v2.md",
		"prompt-template.md",
		"label-prompt-template.md",
		"prompts"
	],
	"scripts": {
		"build": "tsc && npm run copy-prompts",
		"copy-prompts": "mkdir -p dist/prompts/subroutines && cp -r src/prompts/subroutines/*.md dist/prompts/subroutines/ && cp label-prompt-template.md dist/ && cp -r prompts dist/",
		"dev": "tsc --watch",
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest --coverage",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@google/genai": "^1.44.0",
		"@linear/sdk": "^64.0.0",
		"@ngrok/ngrok": "^1.5.1",
		"chokidar": "^4.0.3",
		"fastify": "^5.7.3",
		"fastify-mcp": "^2.1.0",
		"file-type": "^18.7.0",
		"flywheel-claude-runner": "workspace:*",
		"flywheel-config": "workspace:*",
		"flywheel-core": "workspace:*",
		"flywheel-dag-resolver": "workspace:*",
		"flywheel-github-event-transport": "workspace:*",
		"flywheel-linear-event-transport": "workspace:*",
		"flywheel-slack-event-transport": "workspace:*",
		"ignore": "^7.0.5",
		"mem0ai": "^2.3.0",
		"ollama": "^0.6.3",
		"sql.js": "^1.14.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/sql.js": "^1.4.9",
		"@vitest/coverage-v8": "^3.1.4",
		"axios": "^1.13.5",
		"typescript": "^5.3.3",
		"vitest": "^3.1.4",
		"vitest-mock-extended": "^3.1.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
