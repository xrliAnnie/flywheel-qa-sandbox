{
	"name": "flywheel-qa-framework",
	"version": "0.1.0",
	"description": "Reusable QA Agent Framework — plan-aware testing pipeline",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"agents",
		"skills",
		"orchestrator",
		"contracts",
		"templates",
		"examples"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"test:run": "vitest run",
		"typecheck": "tsc --noEmit",
		"shell-export": "node dist/config/shell-export.js"
	},
	"dependencies": {
		"yaml": "^2.7.1",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"typescript": "^5.3.3",
		"vitest": "^3.1.4"
	},
	"publishConfig": {
		"access": "public"
	}
}
